APP_NAME=MediaFlow
APP_ENV=local
APP_KEY=change-me-to-32-chars-secret-key
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=media_downloader
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=10
DB_ECHO=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_RATELIMIT_DB=2
REDIS_STATS_DB=3

TELEGRAM_API_BASE_URL=http://127.0.0.1:8081
TELEGRAM_API_LOCAL=true
CACHE_CHANNEL_ID=-1001234567890

JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

DOWNLOAD_TEMP_DIR=storage/temp
DOWNLOAD_TIMEOUT_SECONDS=300
DOWNLOAD_MAX_FILE_SIZE_MB=2000

LOG_LEVEL=DEBUG
LOG_DIR=storage/logs
